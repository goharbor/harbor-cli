.nh
.TH "HARBOR" "1"  "Harbor Community" "Harbor User Manuals"

.SH NAME
harbor-scanner-list - List scanners


.SH SYNOPSIS
\fBharbor scanner list [flags]\fP


.SH DESCRIPTION
List scanners


.SH OPTIONS
\fB--fuzzy\fP=[]
	Fuzzy match filter (key=value)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for list

.PP
\fB--match\fP=[]
	exact match filter (key=value)

.PP
\fB-q\fP, \fB--query\fP=""
	Query string to query resources

.PP
\fB--range\fP=[]
	range filter (key=min~max)


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB-c\fP, \fB--config\fP=""
	config file (default is $HOME/.config/harbor-cli/config.yaml)

.PP
\fB-o\fP, \fB--output-format\fP=""
	Output format. One of: json|yaml|csv

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	verbose output


.SH SEE ALSO
\fBharbor-scanner(1)\fP