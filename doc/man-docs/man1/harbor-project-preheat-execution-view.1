.nh
.TH "HARBOR" "1"  "Harbor Community" "Harbor User Manuals"

.SH NAME
harbor-project-preheat-execution-view - View preheat execution details


.SH SYNOPSIS
\fBharbor project preheat execution view [PROJECT_NAME|ID] [POLICY_NAME] [EXECUTION_ID] [flags]\fP


.SH DESCRIPTION
Get details of a specific P2P preheat execution under a project


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for view

.PP
\fB--id\fP[=false]
	Use project ID instead of name


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB-c\fP, \fB--config\fP=""
	config file (default is $HOME/.config/harbor-cli/config.yaml)

.PP
\fB-l\fP, \fB--log-format\fP="text"
	Output format for logging. One of: json|text

.PP
\fB-o\fP, \fB--output-format\fP=""
	Output format. One of: json|yaml|csv

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	verbose output


.SH EXAMPLE
.EX
  harbor-cli project preheat execution view [PROJECT_NAME|ID] [POLICY_NAME] [EXECUTION_ID]
.EE


.SH SEE ALSO
\fBharbor-project-preheat-execution(1)\fP