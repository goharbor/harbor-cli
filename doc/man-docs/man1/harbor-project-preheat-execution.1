.nh
.TH "HARBOR" "1"  "Harbor Community" "Harbor User Manuals"

.SH NAME
harbor-project-preheat-execution - Manage preheat executions


.SH SYNOPSIS
\fBharbor project preheat execution [flags]\fP


.SH DESCRIPTION
Manage P2P preheat executions under a project


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for execution


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB-c\fP, \fB--config\fP=""
	config file (default is $HOME/.config/harbor-cli/config.yaml)

.PP
\fB-o\fP, \fB--output-format\fP=""
	Output format. One of: json|yaml|csv

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	verbose output


.SH EXAMPLE
.EX
  harbor-cli project preheat execution list [NAME|ID] [POLICY_NAME]
.EE


.SH SEE ALSO
\fBharbor-project-preheat(1)\fP, \fBharbor-project-preheat-execution-list(1)\fP, \fBharbor-project-preheat-execution-stop(1)\fP, \fBharbor-project-preheat-execution-view(1)\fP