.nh
.TH "HARBOR" "1"  "Harbor Community" "Harbor User Manuals"

.SH NAME
harbor-jobservice-pools-list - List all worker pools


.SH SYNOPSIS
\fBharbor jobservice pools list [flags]\fP


.SH DESCRIPTION
Display all worker pools with their details.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for list


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB-c\fP, \fB--config\fP=""
	config file (default is $HOME/.config/harbor-cli/config.yaml)

.PP
\fB-o\fP, \fB--output-format\fP=""
	Output format. One of: json|yaml

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	verbose output


.SH EXAMPLE
.EX
harbor jobservice pools list
harbor jobservice pool list
.EE


.SH SEE ALSO
\fBharbor-jobservice-pools(1)\fP