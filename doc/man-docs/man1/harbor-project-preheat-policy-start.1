.nh
.TH "HARBOR" "1"  "Harbor Community" "Harbor User Manuals"

.SH NAME
harbor-project-preheat-policy-start - Manually trigger a preheat policy


.SH SYNOPSIS
\fBharbor project preheat policy start [flags]\fP


.SH DESCRIPTION
Manually trigger a specific P2P preheat policy under a project


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for start

.PP
\fB--id\fP[=false]
	Manually trigger preheat policy by project id


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB-c\fP, \fB--config\fP=""
	config file (default is $HOME/.config/harbor-cli/config.yaml)

.PP
\fB-o\fP, \fB--output-format\fP=""
	Output format. One of: json|yaml|csv

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	verbose output


.SH EXAMPLE
.EX
  harbor project preheat policy start [PROJECT_NAME] [POLICY_NAME]
  harbor project preheat policy start [PROJECT_ID] [POLICY_NAME] --id
.EE


.SH SEE ALSO
\fBharbor-project-preheat-policy(1)\fP