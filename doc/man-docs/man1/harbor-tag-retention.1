.nh
.TH "HARBOR" "1"  "Harbor Community" "Harbor User Manuals"

.SH NAME
harbor-tag-retention - Manage retention policies


.SH SYNOPSIS
\fBharbor tag retention [flags]\fP


.SH DESCRIPTION
Manage project tag retention policies in Harbor


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for retention


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB-c\fP, \fB--config\fP=""
	config file (default is $HOME/.config/harbor-cli/config.yaml)

.PP
\fB-o\fP, \fB--output-format\fP=""
	Output format. One of: json|yaml

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	verbose output


.SH SEE ALSO
\fBharbor-tag(1)\fP, \fBharbor-tag-retention-create(1)\fP, \fBharbor-tag-retention-list(1)\fP, \fBharbor-tag-retention-run(1)\fP