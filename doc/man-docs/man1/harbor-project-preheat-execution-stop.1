.nh
.TH "HARBOR" "1"  "Harbor Community" "Harbor User Manuals"

.SH NAME
harbor-project-preheat-execution-stop - Stop preheat execution


.SH SYNOPSIS
\fBharbor project preheat execution stop [PROJECT_NAME|ID] [POLICY_NAME] [EXECUTION_ID] [flags]\fP


.SH DESCRIPTION
Stop a specific P2P preheat execution of a policy under a project


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for stop

.PP
\fB--id\fP[=false]
	Get preheat policy execution by project id


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB-c\fP, \fB--config\fP=""
	config file (default is $HOME/.config/harbor-cli/config.yaml)

.PP
\fB-o\fP, \fB--output-format\fP=""
	Output format. One of: json|yaml|csv

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	verbose output


.SH EXAMPLE
.EX
  harbor-cli project preheat execution stop [NAME|ID] [POLICY_NAME] [EXECUTION_ID]
.EE


.SH SEE ALSO
\fBharbor-project-preheat-execution(1)\fP