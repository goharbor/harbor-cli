.nh
.TH "HARBOR" "1"  "Harbor Community" "Harbor User Manuals"

.SH NAME
harbor-tag-retention-run - run retention policy


.SH SYNOPSIS
\fBharbor tag retention run [PROJECT_NAME] [flags]\fP


.SH DESCRIPTION
trigger retention execution for a project policy


.SH OPTIONS
\fB--dry-run\fP[=false]
	trigger dry-run execution without deleting artifacts

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for run

.PP
\fB--retention-id\fP=0
	retention policy ID


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB-c\fP, \fB--config\fP=""
	config file (default is $HOME/.config/harbor-cli/config.yaml)

.PP
\fB-o\fP, \fB--output-format\fP=""
	Output format. One of: json|yaml

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	verbose output


.SH SEE ALSO
\fBharbor-tag-retention(1)\fP